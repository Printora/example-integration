# Server-only variables (never exposed to client bundle).
PRINTORA_API_KEY=sk_test_your_api_key_here
PRINTORA_API_URL=https://api-staging.printora.ai
PRINTORA_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NODE_ENV=development

# Client-accessible variables (exposed to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: Skip env validation for Docker builds (set to "true" to enable)
# SKIP_ENV_VALIDATION=true
